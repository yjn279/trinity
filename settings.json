{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git worktree:*)",
      "Bash(git -C *:*)",
      "Bash(mkdir -p:*)",
      "Bash(cat .trinity/*)",
      "Bash(git push origin --delete:*)",
      "Bash(git branch -D:*)"
    ]
  }
}
