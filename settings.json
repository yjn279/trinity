{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git worktree:*)",
      "Bash(git -C *:*)",
      "Bash(git update-ref -d *:*)",
      "Bash(mkdir -p:*)",
      "Bash(cat .trinity/*)",
      "Bash(git push:*)",
      "Bash(git ls-remote:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh pr list *:*)",
      "Bash(gh api -X DELETE *:*)",
      "Bash(rm -rf .trinity/*)",
      "Bash(rm -rf *:*)",
      "Bash(gh issue view:*)"
    ]
  }
}
