#!/usr/bin/env bash
# bin/trinity-wait — Orchestrator が呼ぶブロッキングな監視。
#
# フォアグラウンドの Orchestrator は内側ループを駆動しない。代わりに本スクリプトを呼び、
# 「手当てが要るイベント」が起きるまでブロックして待つ。これにより会話を空転させずに
# 進捗を監視でき、Orchestrator の文脈に内側ループのトークンが溜まらない。
#
# 使い方: trinity-wait <session_dir>
#   session_dir に backlog.tsv がある前提。
#
# 次のいずれかが起きたら STATUS 表と EVENT 行を出して終了する:
#   EVENT: needs-input  … いずれかの Issue が確認待ち。ISSUE 行に slug と ask/q のパス。
#                         Orchestrator が AskUserQuestion で問い、ask/a に回答を書く。
#   EVENT: unblocked    … 依存が満たされ起動できる Issue がある（空きスロットあり）。
#                         ISSUE 行の slug について Orchestrator が worktree を用意し再 fanout する。
#   EVENT: done         … backlog の全 Issue が終端（passed/failed/error）に達した。
#   EVENT: timeout      … 監視が上限時間に達した。

set -euo pipefail

SESSION_DIR="${1:?usage: trinity-wait <session_dir>}"
BACKLOG="${SESSION_DIR}/backlog.tsv"
: "${TRINITY_MAX_PARALLEL:=3}"
: "${TRINITY_WAIT_TIMEOUT:=3600}"

status_of() { cat "${SESSION_DIR}/$1/status" 2>/dev/null || echo "-"; }

print_status() {
  printf 'STATUS\n'
  while IFS=$'\t' read -r slug deps _; do
    { [ -z "${slug}" ] || [ "${slug}" = slug ]; } && continue
    printf '  %s\t%s\n' "${slug}" "$(status_of "${slug}")"
  done < "${BACKLOG}"
}

waited=0
while :; do
  needs_input=""
  ready_pending=""
  running=0
  pending=0

  while IFS=$'\t' read -r slug deps _; do
    { [ -z "${slug}" ] || [ "${slug}" = slug ]; } && continue
    s="$(status_of "${slug}")"
    case "${s}" in
      needs-input)
        needs_input="${needs_input} ${slug}"
        ;;
      passed | failed | error)
        ;;  # 終端
      "-")
        pending=$((pending + 1))
        rdy=1
        if [ "${deps}" != "-" ]; then
          IFS=',' read -ra dep_list <<< "${deps}"
          for d in "${dep_list[@]}"; do
            [ "$(status_of "${d}")" = passed ] || rdy=0
          done
        fi
        [ "${rdy}" = 1 ] && ready_pending="${ready_pending} ${slug}"
        ;;
      *)
        running=$((running + 1))  # queued / planning / generating / ...
        ;;
    esac
  done < "${BACKLOG}"

  if [ -n "${needs_input}" ]; then
    print_status
    for slug in ${needs_input}; do
      printf 'ISSUE: %s\tQ: %s/%s/ask/q\n' "${slug}" "${SESSION_DIR}" "${slug}"
    done
    printf 'EVENT: needs-input\n'
    exit 0
  fi

  # 依存が満たされ、かつ空きスロットがある保留 Issue があれば起動を促す。
  if [ -n "${ready_pending}" ] && [ "${running}" -lt "${TRINITY_MAX_PARALLEL}" ]; then
    print_status
    for slug in ${ready_pending}; do
      printf 'ISSUE: %s\n' "${slug}"
    done
    printf 'EVENT: unblocked\n'
    exit 0
  fi

  if [ "${running}" -eq 0 ] && [ "${pending}" -eq 0 ]; then
    print_status
    printf 'EVENT: done\n'
    exit 0
  fi

  sleep 5
  waited=$((waited + 5))
  if [ "${waited}" -ge "${TRINITY_WAIT_TIMEOUT}" ]; then
    print_status
    printf 'EVENT: timeout\n'
    exit 0
  fi
done
