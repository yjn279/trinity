#!/usr/bin/env bash
# bin/trinity — Trinity シェルハーネス唯一の実行ファイル。
#
# サブコマンド:
#   loop <RUN_DIR> <WORKTREE_DIR> <BRANCH>
#       Plan → Generate → 道具 → Evaluate を TRINITY_MAX_LOOPS 回（既定 5）反復する。
#       確認が要るときは RUN_DIR/ask/q を書いて needs-input でブロックする。
#       中断後の再起動では RUN_DIR の既存成果物から到達点を判定し中断点から再開する。
#   supervise <SESSION_DIR>
#       backlog.tsv（slug・worktree・branch・title の薄い起動リスト）を読み、
#       Issue を TRINITY_MAX_PARALLEL（既定 3）の範囲で背景起動し、空きスロットに
#       次の行を順次投入して監視する。手当てが要るイベントまでブロックして
#       STATUS 表と EVENT: を返す。
#
# 環境変数: TRINITY_MAX_LOOPS / TRINITY_ASK_TIMEOUT /
#            TRINITY_MAX_PARALLEL / TRINITY_WAIT_TIMEOUT

set -euo pipefail

TRINITY_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export TRINITY_ROOT

trinity::usage() {
  [ -n "${1:-}" ] && printf 'trinity: %s\n' "$1" >&2
  printf '使い方:\n  trinity loop <RUN_DIR> <WORKTREE_DIR> <BRANCH>\n  trinity supervise <SESSION_DIR>\n' >&2
  exit 1
}

SUBCOMMAND="${1:-}"
case "${SUBCOMMAND}" in
  loop | supervise) shift ;;
  "") trinity::usage "サブコマンドが必要です" ;;
  *)  trinity::usage "未知のサブコマンド: ${SUBCOMMAND}" ;;
esac

# --- loop — 1 Issue の収束ループ -------------------------------------------
loop_main() {
  local RUN_DIR WORKTREE_DIR BRANCH
  RUN_DIR="${1:?usage: trinity loop <RUN_DIR> <WORKTREE_DIR> <BRANCH>}"
  WORKTREE_DIR="${2:?WORKTREE_DIR required}"
  BRANCH="${3:?BRANCH required}"
  export RUN_DIR WORKTREE_DIR BRANCH

  mkdir -p "${RUN_DIR}/ask"
  # shellcheck source=lib/actors.sh
  . "${TRINITY_ROOT}/lib/actors.sh"

  : "${TRINITY_MAX_LOOPS:=5}"
  : "${TRINITY_ASK_TIMEOUT:=1800}"

  loop::ask() {
    local loop="$1" waited=0
    awk '/^## 要確認の論点/{p=1;print;next} p&&/^## /{p=0} p' \
      "${RUN_DIR}/plan.md" > "${RUN_DIR}/ask/q"
    rm -f "${RUN_DIR}/ask/a"
    trinity::status needs-input
    trinity::log "ループ ${loop}: 確認待ち（ask/q を Orchestrator が拾う）"
    while [ ! -f "${RUN_DIR}/ask/a" ]; do
      sleep 5
      waited=$((waited + 5))
      if [ "${waited}" -ge "${TRINITY_ASK_TIMEOUT}" ]; then
        trinity::log "確認待ちがタイムアウトした"
        trinity::status error
        exit 1
      fi
    done
    { printf '\n## 確定事項（ループ %s で確認済み）\n' "${loop}"; cat "${RUN_DIR}/ask/a"; } \
      >> "${RUN_DIR}/requirement.md"
    rm -f "${RUN_DIR}/ask/q" "${RUN_DIR}/ask/a"
  }

  # RUN_DIR の既存成果物から再開ループ番号・モード・入口を返す。
  # 出力形式: "<n> <mode> <entrance>"（例: "2 plan B"）
  # PASS 済みのときは "PASS" のみを返す。
  loop::resume_point() {
    local k=0 num="" verdict="" f
    for f in "${RUN_DIR}"/eval-*.md; do
      [ -f "$f" ] || continue
      num="${f##*/eval-}"
      num="${num%.md}"
      case "${num}" in *[!0-9]*) continue ;; esac
      verdict="$(grep -m1 '^VERDICT:' "$f" 2>/dev/null | awk '{print $2}')" || continue
      case "${verdict}" in
        PASS | NEEDS_REVISION | FAIL) ;;
        *) continue ;;
      esac
      [ "${num}" -gt "${k}" ] && k="${num}"
    done

    if [ "${k}" -eq 0 ]; then
      printf '1 plan A\n'; return
    fi

    verdict="$(grep -m1 '^VERDICT:' "${RUN_DIR}/eval-${k}.md" 2>/dev/null | awk '{print $2}')" || true
    [ "${verdict}" = PASS ] && { printf 'PASS\n'; return; }

    local n mode entrance
    n=$((k + 1))
    case "${verdict}" in
      NEEDS_REVISION) mode=plan ;;
      *)              mode=revise ;;
    esac
    entrance=A
    if find "${RUN_DIR}" -maxdepth 1 -name "gen-${n}-*" 2>/dev/null | grep -q .; then
      entrance=B
    fi
    printf '%s %s %s\n' "${n}" "${mode}" "${entrance}"
  }

  trinity::log "loop 開始: ${BRANCH}"

  local resume loop mode entrance rc skip_to_tools
  resume="$(loop::resume_point)"
  if [ "${resume}" = PASS ]; then
    trinity::log "再開判定: 既に PASS 済み。再実行しない。"
    trinity::status passed
    exit 0
  fi
  read -r loop mode entrance <<< "${resume}"
  skip_to_tools=""
  if [ "${loop}" -gt 1 ]; then
    trinity::log "再開: ループ ${loop} から ${mode}（入口${entrance}）で再開する"
    [ "${entrance}" = B ] && skip_to_tools=1
  fi

  while [ "${loop}" -le "${TRINITY_MAX_LOOPS}" ]; do
    if [ -z "${skip_to_tools}" ]; then
      if [ "${mode}" = plan ]; then
        if ! trinity::plan "${loop}"; then
          rc=$?
          if [ "${rc}" -eq 10 ]; then
            loop::ask "${loop}"
            continue
          fi
          exit 1
        fi
        trinity::generate "${loop}"
      else
        trinity::revise "${loop}"
      fi
    fi
    skip_to_tools=""

    trinity::tools "${loop}"

    rc=0
    trinity::evaluate "${loop}" || rc=$?
    case "${rc}" in
      0) trinity::log "ループ ${loop} で PASS。PR 作成へ。"; exit 0 ;;
      2) mode=plan ;;    # NEEDS_REVISION → 再計画
      3) mode=revise ;;  # FAIL → 既存計画の範囲内で修正
      *) exit 1 ;;
    esac
    loop=$((loop + 1))
  done

  trinity::status failed
  trinity::log "${TRINITY_MAX_LOOPS} ループで PASS に到達しなかった"
  exit 2
}

# --- supervise — 複数 Issue の起動＋監視 ------------------------------------
supervise_main() {
  local SESSION_DIR BACKLOG
  SESSION_DIR="${1:?usage: trinity supervise <SESSION_DIR>}"
  BACKLOG="${SESSION_DIR}/backlog.tsv"

  : "${TRINITY_MAX_PARALLEL:=3}"
  : "${TRINITY_WAIT_TIMEOUT:=3600}"

  status_of() {
    local f="${SESSION_DIR}/$1/status"
    [ -f "$f" ] && printf '%s\n' "$(< "$f")" || echo "-"
  }

  running_count() {  # queued も計上し起動直後の監視レースを防ぐ
    local n=0 s
    while IFS=$'\t' read -r slug _remainder; do
      { [ -z "${slug}" ] || [ "${slug}" = "slug" ]; } && continue
      s="$(status_of "${slug}")"
      case "${s}" in
        passed | failed | error | "-" | "") ;;
        *) n=$((n + 1)) ;;
      esac
    done < "${BACKLOG}"
    printf '%s' "${n}"
  }

  print_status() {
    printf 'STATUS\n'
    while IFS=$'\t' read -r slug _worktree _branch _title; do
      { [ -z "${slug}" ] || [ "${slug}" = "slug" ]; } && continue
      printf '  %s\t%s\n' "${slug}" "$(status_of "${slug}")"
    done < "${BACKLOG}"
  }

  launch_ready() {
    local launched=0 current_running slug worktree branch title run_dir
    current_running="$(running_count)"
    while IFS=$'\t' read -r slug worktree branch title; do
      { [ -z "${slug}" ] || [ "${slug}" = "slug" ]; } && continue
      [ "${worktree}" = "-" ] && continue
      [ -f "${SESSION_DIR}/${slug}/status" ] && continue

      if [ "${current_running}" -ge "${TRINITY_MAX_PARALLEL}" ]; then
        printf 'supervise: 並列上限 %s に到達。空きスロットができたら再起動する。\n' \
          "${TRINITY_MAX_PARALLEL}" >&2
        break
      fi

      run_dir="${SESSION_DIR}/${slug}"
      mkdir -p "${run_dir}"
      printf 'queued\n' > "${run_dir}/status"
      printf 'supervise: launch %s\t(branch %s)\t%s\n' "${slug}" "${branch}" "${title}" >&2

      nohup "${TRINITY_ROOT}/bin/trinity" loop "${run_dir}" "${worktree}" "${branch}" \
        >> "${run_dir}/pipeline.out" 2>&1 &
      printf '%s\n' "$!" > "${run_dir}/pid"
      launched=$((launched + 1))
      current_running=$((current_running + 1))
    done < "${BACKLOG}"
    printf 'supervise: %d 本のパイプラインを起動した\n' "${launched}" >&2
  }

  launch_ready

  local waited=0 needs_input local_running local_pending slug s
  while :; do
    needs_input=""
    local_running=0
    local_pending=0

    while IFS=$'\t' read -r slug _remainder; do
      { [ -z "${slug}" ] || [ "${slug}" = "slug" ]; } && continue
      s="$(status_of "${slug}")"
      case "${s}" in
        needs-input)
          needs_input="${needs_input} ${slug}" ;;
        passed | failed | error)
          ;;
        "-")
          local_pending=$((local_pending + 1)) ;;
        *)
          local_running=$((local_running + 1)) ;;
      esac
    done < "${BACKLOG}"

    if [ -n "${needs_input}" ]; then
      print_status
      for slug in ${needs_input}; do
        printf 'ISSUE: %s\tQ: %s/%s/ask/q\n' "${slug}" "${SESSION_DIR}" "${slug}"
      done
      printf 'EVENT: needs-input\n'
      exit 0
    fi

    # 空きスロットがあり未起動行が残っていれば追加投入
    if [ "${local_pending}" -gt 0 ] && [ "${local_running}" -lt "${TRINITY_MAX_PARALLEL}" ]; then
      launch_ready
    fi

    if [ "${local_running}" -eq 0 ] && [ "${local_pending}" -eq 0 ]; then
      print_status
      printf 'EVENT: done\n'
      exit 0
    fi

    sleep 5
    waited=$((waited + 5))
    if [ "${waited}" -ge "${TRINITY_WAIT_TIMEOUT}" ]; then
      print_status
      printf 'EVENT: timeout\n'
      exit 0
    fi
  done
}

# --- ディスパッチ -------------------------------------------------------------
case "${SUBCOMMAND}" in
  loop)      loop_main "$@" ;;
  supervise) supervise_main "$@" ;;
esac
